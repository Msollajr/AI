# =============================================================================
# UDSM Student Support AI — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is listed in .gitignore and .dockerignore — it will never be committed
# or baked into the Docker image.
# =============================================================================

# ── LLM / Ollama ──────────────────────────────────────────────────────────────
# Internal Docker network URL for Ollama (do not change for Docker Compose deployments)
OLLAMA_API_URL=http://ollama:11434/api/generate

# The Ollama model to use. Must match the model pulled by the ollama-setup service.
# Available models: qwen2.5:3b, qwen2.5:7b, llama3.2:3b, mistral:7b
MODEL_NAME=qwen2.5:3b

# ── FastAPI Server ────────────────────────────────────────────────────────────
# Host and port uvicorn listens on inside the container (usually no need to change)
API_HOST=0.0.0.0
API_PORT=8000

# ── Resource Limits (optional overrides) ─────────────────────────────────────
# These are set in docker-compose.yml but can be overridden here if needed.
# OLLAMA_MEMORY_LIMIT=8g
# OLLAMA_CPU_LIMIT=4

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/student_support_db

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a secret key: openssl rand -hex 32
SECRET_KEY=your-super-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
